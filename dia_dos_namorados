<script>
// Contador regressivo pro Dia dos Namorados
const countDownDate = new Date("Jun 12, 2026 00:00:00").getTime();
const countdown = setInterval(() => {
  const now = new Date().getTime();
  const distance = countDownDate - now;
  document.getElementById("days").innerText = Math.floor(distance / (1000 * 60 * 60 * 24));
  document.getElementById("hours").innerText = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
  document.getElementById("minutes").innerText = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
  document.getElementById("seconds").innerText = Math.floor((distance % (1000 * 60)) / 1000);
  if (distance < 0) clearInterval(countdown);
}, 1000);

// Demo interativa
function atualizarPreview() {
  const nome1 = document.getElementById("nome1").value || "Nome 1";
  const nome2 = document.getElementById("nome2").value || "Nome 2";
  const dataInicio = new Date(document.getElementById("dataInicio").value);
  document.getElementById("previewNomes").innerText = `${nome1} & ${nome2}`;
  
  const agora = new Date();
  let anos = agora.getFullYear() - dataInicio.getFullYear();
  let meses = agora.getMonth() - dataInicio.getMonth();
  if (meses < 0) { anos--; meses += 12; }
  document.getElementById("previewTempo").innerText = `${anos} ano${anos!==1?'s':''}, ${meses} mes${meses!==1?'es':''}`;
}

// FAQ Accordion
document.querySelectorAll('.faq-question').forEach(item => {
  item.addEventListener('click', () => {
    item.parentNode.classList.toggle('active');
  });
});

// Contador animado de stats
const stats = document.querySelectorAll('.stat-number');
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const target = +entry.target.getAttribute('data-target');
      let count = 0;
      const updateCount = () => {
        const increment = target / 100;
        if (count < target) {
          count += increment;
          entry.target.innerText = Math.ceil(count);
          setTimeout(updateCount, 20);
        } else {
          entry.target.innerText = target;
        }
      };
      updateCount();
      observer.unobserve(entry.target);
    }
  });
});
stats.forEach(stat => observer.observe(stat));

// Trocar links de checkout aqui: LINK_CHECKOUT_ESSENCIAL, LINK_CHECKOUT_COMPLETO, LINK_CHECKOUT_VITALICIO
</script>

